# Baseline API endpoints
# Uncomment and fill the providers you have access to.

# Condition A: Opus (Anthropic API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# Condition B: GPT (OpenAI API, or any OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Condition C: Qwen3.5-plus via mulerouter
QWEN_API_KEY=
QWEN_BASE_URL=https://api.mulerouter.ai/vendors/openai/v1
QWEN_MODEL=qwen3.5-plus

# Condition D: Qwen3.6-35B-A3B (MoE) via mulerouter
QWEN36_35B_API_KEY=
QWEN36_35B_BASE_URL=https://api.mulerouter.ai/vendors/openai/v1
QWEN36_35B_MODEL=Qwen/Qwen3.6-35B-A3B

# Condition E: Qwen3.6-27B (Dense) via mulerouter
QWEN36_27B_API_KEY=
QWEN36_27B_BASE_URL=https://api.mulerouter.ai/vendors/openai/v1
QWEN36_27B_MODEL=Qwen/Qwen3.6-27B

# Condition F: Qwen3.5-27B (Dense) via mulerouter
QWEN35_27B_API_KEY=
QWEN35_27B_BASE_URL=https://api.mulerouter.ai/vendors/openai/v1
QWEN35_27B_MODEL=Qwen/Qwen3.5-27B

# Condition G: Qwen3.5-4B (Dense compact) via mulerouter
QWEN35_4B_API_KEY=
QWEN35_4B_BASE_URL=https://api.mulerouter.ai/vendors/openai/v1
QWEN35_4B_MODEL=Qwen/Qwen3.5-4B

# Condition H: Kimi-K2.6 (Moonshot AI)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshotai/Kimi-K2.6

# Tinker (for SFT/RLVR training, Phase 2+)
TINKER_API_KEY=

# Weights & Biases (experiment tracking)
WANDB_API_KEY=

# Pi RPC (for RLVR rollout environment, Phase 3+)
PI_RPC_URL=http://localhost:8080
