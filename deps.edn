{:paths ["src" "data"]
 :deps {org.clojure/clojure {:mvn/version "1.12.4"}
        org.clojure/data.json {:mvn/version "2.5.1"}}
 :aliases
 {:bench {:main-opts ["-m" "learn.benchmark"]}
  :curate {:main-opts ["-m" "learn.curate"]}
  :evaluate {:main-opts ["-m" "learn.evaluate"]}
  :aggregate {:main-opts ["-m" "learn.aggregate"]}
  :ingest {:main-opts ["-m" "learn.ingest"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/url "https://github.com/cognitect-labs/test-runner.git"
                       :sha "705ad25bbf0228b1c38d0214b7178a050ee6f815"}
                      org.clojure/test.check {:mvn/version "1.1.1"}}}}}
