{"repo": "nubank/matcher-combinators", "track": "internal", "license": "MIT", "source_path": "src/cljc/matcher_combinators/matchers.cljc", "var_name": "equals", "ns_name": "matcher-combinators.matchers", "private": false, "docstring": "Matcher that will match when the given value is exactly the same as the\n  `expected`.\n\n  When `expected` is:\n   - A scalar or function: Value equality is used\n   - A composite data-structure (map, vector, etc): each element in `actual` must\n  match a corresponding element in `expected`. Consistent with other matchers,\n  equals is not recursively applied to sub-elements. This means that nested maps,\n  for example, continue using their default matcher. If you want to do a deep\n  match, consider using `match-with` instead.", "argvec": "[expected]", "form_line_count": 21, "form_char_count": 884, "matched_tests": ["test/cljs/matcher_combinators/cljs_example_test.cljs", "test/clj/matcher_combinators/parser_test.clj", "test/clj/matcher_combinators/midje_test.clj", "test/clj/matcher_combinators/core_test.clj", "test/clj/matcher_combinators/matchers_test.clj", "test/clj/matcher_combinators/test_test.clj", "test/clj/matcher_combinators/printer_test.clj"], "test_evidence": ["(is (match? (m/match-with [map? m/equals]", "(is (no-match? (m/match-with [map? m/equals]", "(is (= (core/match (m/equals {:a (m/equals 10)}) {:a 10})"], "contract_type": "docstring_and_test", "contract_score": 3}
{"repo": "nubank/matcher-combinators", "track": "internal", "license": "MIT", "source_path": "src/cljc/matcher_combinators/matchers.cljc", "var_name": "nested-equals", "ns_name": "matcher-combinators.matchers", "private": false, "docstring": "A matcher that always uses the `equals` matcher at every level of nesting.\n\n  Useful given that matchers usually only change the first level of the data\n  they are applied to, leaving nested data to use the default matcher of that\n  type of data. For instance, this can be used to assert that any nested map\n  has exactly the same keys and matching values as provided in the `expected`,\n  and no more.\n\n  Note: this excludes functions, which continue to be invoked\n  as predicates, and regex, which continue to be invoked with `regex`,\n  instead of being compared via the `equals` matcher.", "argvec": "[expected]", "form_line_count": 12, "form_char_count": 665, "matched_tests": ["test/clj/matcher_combinators/matchers_test.clj"], "test_evidence": ["(is (match? (m/nested-equals {:user1 {:id 5 :name \"hennix\"}", "(is (no-match? (m/nested-equals {:user1 {:id 5}"], "contract_type": "docstring_and_test", "contract_score": 3}
